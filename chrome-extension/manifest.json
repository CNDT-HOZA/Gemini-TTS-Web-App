{
  "name": "Gemini TTS - Voice Studio",
  "version": "1.0.0",
  "description": "Tự động chuyển văn bản thành giọng nói từ Google Sheet",
  "manifest_version": 3,
  "permissions": [
    "storage",
    "notifications",
    "alarms",
    "offscreen"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*",
    "https://docs.google.com/*",
    "https://script.google.com/*"
  ],
  "background": {
    "service_worker": "js/background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Gemini TTS",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
